#!/usr/bin/env python3

import os, sys
import argparse
import re
import subprocess

parser = argparse.ArgumentParser()
parser.add_argument("buildconfig", default="../.buildconfig",
            help="the buildconfig file")
parser.add_argument("header_file", default="./autogen_boot0_dts_header.h",
            help="the output header file")
args = parser.parse_args()

if not os.path.exists(args.buildconfig):
    print("%s not exists" % args.buildconfig)
    sys.exit(1)

configs = {}
kernel_dts_path = None
uboot_dts_path = None
board_config_dir = None
output_ctx = None

# ------------------------------------------------------------------------------------

def parse_dts_reserved_mem(tree, node_path):
    global output_ctx
    reserved_list = []

    node = tree[node_path]
    if 'subnode' in node.keys():
        for sub in node['subnode']:
            subnode = tree[node_path + '/' + sub]
            if 'reg' not in subnode['property'].keys():
                continue
            node_name = subnode['name']
            reg = subnode['property']['reg']['val']
            # reg format: <addr_hi addr_lo size_hi size_lo>
            reg = reg.replace('<', '')
            reg = reg.replace('>', '')
            reg_info = reg.strip().split()
            if len(reg_info) == 2:
                addr = reg_info[0]
                size = reg_info[1]
            else:
                addr = (int(reg_info[0], 16) << 32) + int(reg_info[1], 16)
                size = (int(reg_info[2], 16) << 32) + int(reg_info[3], 16)
            reserved_list.append([node_name, addr, size])

    for item in reserved_list:
        #output_ctx.write('#define DTS_RESERVED_%s\t\t%s\n' % (str(item[0]), item[0]))
        output_ctx.write('#define DTS_RESERVED_%s_ADDR\t0x%x\n' % (str(item[0]), item[1]))
        output_ctx.write('#define DTS_RESERVED_%s_SIZE\t0x%x\n\n' % (str(item[0]), item[2]))

    output_ctx.write('#define DTS_RESERVED_ADDR(x)\t\tDTS_RESERVED_##x##_ADDR\n')
    output_ctx.write('#define DTS_RESERVED_SIZE(x)\t\tDTS_RESERVED_##x##_SIZE\n')
    output_ctx.write('\n')

kernel_dts_target_node = {
        "reserved-memory" : parse_dts_reserved_mem
}

def parse_dts_flashmap(tree, node_path):
    global output_ctx

    reserved_list = []

    node = tree[node_path]
    if 'subnode' in node.keys():
        for sub in node['subnode']:
            subnode = tree[node_path + '/' + sub]
            node_name = subnode['name']

            # Skip nand flash map parse
            if 'nand' in node_name:
                continue

            if 'status' not in subnode['property'].keys():
                continue

            if subnode['property']['status']['val'] != '\"okay\"':
                continue

            target_prop = [
                'logic_offset', 'secure_logic_offset', 'boot_param_start', 'boot_param_size',
                'uboot_start', 'uboot_size'
            ]
            for prop_name in target_prop:
                if prop_name in subnode['property'].keys():
                    prop_val = subnode['property'][prop_name]['val']
                    prop_val = prop_val.replace('<', '')
                    prop_val = prop_val.replace('>', '').strip()
                    output_ctx.write('#define DTS_FLASHMAP_{}_{}\t\t{}\n'.format(node_name, prop_name, prop_val))
            output_ctx.write('\n')

uboot_dts_target_node = {
        "sunxi_flashmap" : parse_dts_flashmap
}

