include $(TOPDIR)/mk/config.mk
LIB	=  libfdt.o

COBJS-y += fdt.o
COBJS-y += fdt_ro.o
COBJS-y += fdt_wip.o
COBJS-y += fdt_sw.o
COBJS-y += fdt_rw.o
COBJS-y += fdt_strerror.o
COBJS-y += fdt_empty_tree.o
COBJS-y += fdt_addresses.o
COBJS-$(CFG_OF_LIBFDT_OVERLAY) += fdt_overlay.o

SRCS	:= $(COBJS-y:.o=.c)
OBJS	:= $(addprefix $(obj),$(COBJS-y))

all:	$(obj).depend $(LIB)

$(LIB):	$(OBJS)
	$(call cmd_link_o_target, $(OBJS))

#########################################################################

depend:	$(obj).depend
.PHONY: depend

# defines $(obj).depend target
include $(TOPDIR)/mk/rules.mk
